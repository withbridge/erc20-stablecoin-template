# ERC20 Stablecoin Template — Deployment Configuration
#
# Deployer auth: use --private-key, --ledger, or --account <keystore>
#   cast wallet import <name> --private-key <key>

# ── Always Required ──────────────────────────────────────────────
RPC_URL=
ETHERSCAN_API_KEY=

# ════════════════════════════════════════════════════════════════
# deploy-new-chain.sh  (run once per chain)
# ════════════════════════════════════════════════════════════════

# ReserveLedger token config (steps 01-02)
RL_NAME="Reserve Ledger Dollar"
RL_SYMBOL="RD"
RL_DECIMALS=6
POLICY_ADMIN=0x0000000000000000000000000000000000000000
RL_SALT_NONCE=0

# ════════════════════════════════════════════════════════════════
# deploy-new-stablecoin.sh  (run once per stablecoin)
#
# Usage:
#   bash scripts/deploy-new-stablecoin.sh \
#     <AUTH_REGISTRY> <RESERVE_LEDGER> <TOKEN_AUTHORITY> <TRANSFER_POLICY_ID>
# ════════════════════════════════════════════════════════════════

# Stablecoin token config (step 04)
STABLECOIN_NAME="USD Stablecoin"
STABLECOIN_SYMBOL="USDB"
STABLECOIN_DECIMALS=6
SC_SALT_NONCE=2

# Minting (step 05)
MINTER_ADDRESS=0x0000000000000000000000000000000000000000
TXN_MINT_LIMIT=1000000000000
MINTER_ALLOWANCE=1000000000000000

# Supply caps (step 05)
RL_MAX_SUPPLY=1000000000000000
STABLECOIN_MAX_SUPPLY=1000000000000000

# Operational roles on the stablecoin (step 05)
PAUSER_ADDRESS=0x0000000000000000000000000000000000000000
UNPAUSER_ADDRESS=0x0000000000000000000000000000000000000000
BLOCKED_ADDRESS_BURNER_ADDRESS=0x0000000000000000000000000000000000000000

# Final admin addresses — handed ownership after deploy (step 05)
RL_ADMIN=0x0000000000000000000000000000000000000000
STABLECOIN_ADMIN=0x0000000000000000000000000000000000000000
TOKEN_AUTHORITY_ADMIN=0x0000000000000000000000000000000000000000

# ════════════════════════════════════════════════════════════════
# 06_Verify.s.sol  (post-deploy verification)
#
# Usage:
#   AUTH_REGISTRY=0x... RESERVE_LEDGER=0x... \
#   TOKEN_AUTHORITY=0x... STABLECOIN=0x... \
#   forge script scripts/06_Verify.s.sol --rpc-url $RPC_URL
# ════════════════════════════════════════════════════════════════
AUTH_REGISTRY=0x0000000000000000000000000000000000000000
RESERVE_LEDGER=0x0000000000000000000000000000000000000000
TOKEN_AUTHORITY=0x0000000000000000000000000000000000000000
STABLECOIN=0x0000000000000000000000000000000000000000
